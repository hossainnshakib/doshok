# ───────────────────────────────────────────────
# Doshok — Environment Variables
# ───────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
#   cp .env.example .env.local
# ───────────────────────────────────────────────

# ── Database ────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/doshok"

# ── Auth (NextAuth v5) ──────────────────────────
NEXTAUTH_SECRET="change-this-to-a-random-64-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Email (Resend) ──────────────────────────────
# Resend domain verification required for doshok.com
# From addresses must match a verified sending domain.
RESEND_API_KEY="re_..."
ADMIN_EMAIL="admin@doshok.com"
FROM_EMAIL="Doshok <noreply@doshok.com>"
OTP_FROM_EMAIL="Doshok <otp@doshok.com>"

# ── Public Site URL ─────────────────────────────
# Used in sitemap.xml and robots.txt
NEXT_PUBLIC_SITE_URL="https://doshok.com"

# ── Cloudinary (image upload) ───────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Payment Gateway Credential Encryption ───────
# Reserved for future online payment rebuilds. Doshok V1.1 is COD-only.
# If not set, falls back to NEXTAUTH_SECRET (local dev only).
PAYMENT_CREDENTIALS_SECRET=""

# ── Firebase Phone OTP (frontend) ───────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ── Firebase Admin (backend token verification) ─
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── OTP (SMS verification) ─────────────────────
# OTP_PROVIDER should be set to "firebase" (Firebase Phone Auth).
# Other providers are not supported.
OTP_PROVIDER="firebase"

# ── Cron Jobs ──────────────────────────────────
# Used to authenticate cron job requests.
# Schedule /api/cron/release-reservations in production.
# Do not schedule /api/cron/cancel-expired-payments while V1.1 is COD-only.
CRON_SECRET=""

# ── Order Success Token ──────────────────────────
# Required in production.
# Used to sign order success page access tokens.
# Must be a strong random secret. Generate with:
#   openssl rand -base64 48
SUCCESS_TOKEN_SECRET="change-this-strong-random-secret"
