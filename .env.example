# ───────────────────────────────────────────────
# Doshok — Environment Variables
# ───────────────────────────────────────────────
# Copy this file to .env.local and fill in values.
#   cp .env.example .env.local
# ───────────────────────────────────────────────

# ── Database ────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/doshok"

# ── Auth (NextAuth v5) ──────────────────────────
NEXTAUTH_SECRET="change-this-to-a-random-64-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Email (Resend) ──────────────────────────────
RESEND_API_KEY="re_..."
ADMIN_EMAIL="admin@doshok.com"
FROM_EMAIL="noreply@doshok.com"

# ── Cloudinary (image upload) ───────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Payment Gateway Credential Encryption ───────
# Used to encrypt payment provider credentials at rest.
# If not set, falls back to NEXTAUTH_SECRET (local dev only).
PAYMENT_CREDENTIALS_SECRET=""

# ── Courier API Credential Encryption ───────────
# Used to encrypt courier provider credentials at rest.
# If not set, falls back to NEXTAUTH_SECRET (local dev only).
COURIER_CREDENTIALS_SECRET=""

# ── bKash (Sandbox default) ─────────────────────
BKASH_APP_KEY=""
BKASH_APP_SECRET=""
BKASH_USERNAME=""
BKASH_PASSWORD=""
BKASH_BASE_URL="https://tokenized.sandbox.bka.sh/v1.2.0-beta"

# ── SSLCommerz (placeholder) ────────────────────
# SSLCOMMERZ_STORE_ID=""
# SSLCOMMERZ_STORE_PASSWORD=""
# SSLCOMMERZ_BASE_URL=""

# ── aamarPay (placeholder) ──────────────────────
# AAMARPAY_STORE_ID=""
# AAMARPAY_SIGNATURE_KEY=""
# AAMARPAY_BASE_URL=""

# ── Courier placeholders (setup-ready) ──────────
# PATHAO_CLIENT_ID=""
# PATHAO_CLIENT_SECRET=""
# STEADFAST_API_KEY=""
# STEADFAST_SECRET_KEY=""
# REDX_API_TOKEN=""

# ── Firebase Phone OTP (frontend) ───────────────
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# ── Firebase Admin (backend token verification) ─
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""

# ── OTP (SMS verification) ─────────────────────
# OTP_PROVIDER should be set to "firebase" (Firebase Phone Auth).
# Other providers are not supported.
OTP_PROVIDER="firebase"
OTP_FROM_EMAIL=""

# ── Cron Jobs ──────────────────────────────────
# Used to authenticate cron job requests.
CRON_SECRET=""
