generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  phoneVerifiedAt DateTime?
  dateOfBirth   DateTime?
  gender        String?
  password      String?
  role          String    @default("customer")
  status        String    @default("active")
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     UserAddress[]
  emailTokens   EmailVerificationToken[]
  resetTokens   PasswordResetToken[]
  recoveryTokensCreated RecoveryCheckoutToken[] @relation("CreatedRecoveryTokens")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  image     String?
  parentId  String?
  parent    Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryHierarchy")
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([parentId])
}

model Product {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  description        String?
  shortDescription   String?
  price              Int
  oldPrice           Int?
  images             String[]
  categoryId         String
  category           Category         @relation(fields: [categoryId], references: [id])
  variants           ProductVariant[]
  specifications     ProductSpecification[]
  orderItems         OrderItem[]
  stockMovements     StockMovement[]
  sizeCharts         ProductSizeChart[]
  featured           Boolean          @default(false)
  status             String           @default("Draft")
  pageType           String           @default("NORMAL")
  defaultCouponCode  String?
  landingHeadline    String?
  landingSubheadline String?
  landingCopy        String?
  landingHeroImage   String?
  material           String?
  careInstructions   String?
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  seoImage           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model ProductSpecification {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  value     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductVariant {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size             String
  color            String
  colorHex         String?
  stock            Int     @default(0)
  reservedStock    Int     @default(0)
  lowStockThreshold Int    @default(5)
  sku              String?
  orderItems       OrderItem[]
  stockMovements   StockMovement[]

  @@unique([productId, size, color])
  @@index([productId])
}

model StockMovement {
  id             String   @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderId        String?
  order          Order?   @relation(fields: [orderId], references: [id])
  orderItemId    String?
  type           String
  quantity       Int
  beforeStock    Int?
  afterStock     Int?
  beforeReserved Int?
  afterReserved  Int?
  reason         String?
  note           String?
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([productId])
  @@index([variantId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

model DeliveryZone {
  id    String @id @default(cuid())
  name  String @unique
  fee   Int
}

model Address {
  id          String @id @default(cuid())
  division    String
  district    String
  thana       String
  fullAddress String
  phone       String
  orderId     String @unique
  order       Order  @relation(fields: [orderId], references: [id])
}

model UserAddress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   @default("Home")
  recipientName String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  zone          String
  postalCode    String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Order {
  id             String          @id @default(cuid())
  orderNumber    String          @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  userId         String?
  user           User?           @relation(fields: [userId], references: [id])
  items          OrderItem[]
  address        Address?
  shipment       OrderShipment?
  stockMovements StockMovement[]
  subtotal       Int
  deliveryFee    Int
  discount       Int             @default(0)
  total          Int
  paidAmount     Int             @default(0)
  paymentMethod  String
  paymentStatus  String          @default("pending")
  bkashTrxId     String?
  orderStatus    String          @default("pending")
  notes          String?
  couponCode     String?
  paymentExpiresAt   DateTime?
  paymentVerifiedAt  DateTime?
  stockRestoredAt     DateTime?
  refundedAt     DateTime?
  refundAmount   Int              @default(0)
  refundReason   String?
  refundTrxId    String?
  transactions   PaymentTransaction[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
  @@index([bkashTrxId])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  name      String
  size      String?
  color     String?
  quantity  Int
  price     Int
}

model PaymentTransaction {
  id               String    @id @default(cuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         String    @default("BKASH")
  trxId            String    @unique
  amount           Int
  status           String    @default("initiated")
  providerResponse String?
  initiatedAt      DateTime  @default(now())
  verifiedAt       DateTime?
  completedAt      DateTime?

  @@index([orderId])
  @@index([trxId])
  @@index([status])
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Int
  type       String   @default("flat")
  minOrder   Int      @default(0)
  maxUses    Int?
  maxUsesPerCustomer Int?
  usedCount  Int      @default(0)
  expiresAt  DateTime?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  usages     CouponUsage[]
}

model CouponUsage {
  id        String   @id @default(cuid())
  couponId  String
  coupon    Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId    String?
  email     String
  orderId   String
  createdAt DateTime @default(now())

  @@index([couponId, userId])
  @@index([couponId, email])
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model SiteSettings {
  id              String  @id @default("default")
  brandName       String  @default("DOSHOK")
  supportEmail    String  @default("hello@doshok.com")
  phone           String  @default("")
  whatsapp        String?
  facebookUrl     String?
  instagramUrl    String?
  tiktokUrl       String?
  youtubeUrl      String?
  address         String  @default("We deliver across all districts of Bangladesh. Our operation hub is in Chattogram.")
  footerText      String  @default("Premium Bangladeshi fashion for the modern wardrobe.")
  footerLinks     String  @default("[]")
  headerQuickLinks String @default("[]")
  accentColor     String  @default("#364152")
  buttonRadius    String  @default("xl")
  cardRadius      String  @default("1.5rem")
  storefrontTone  String  @default("light")
  adminAccentTone String  @default("neutral")
  updatedAt       DateTime @updatedAt
}

model HomepageConfig {
  id                    String @id @default("homepage")
  heroTitle             String @default("Doshok — Style That Speaks")
  heroSubtitle          String @default("Premium Bangladeshi fashion for the modern wardrobe.")
  heroImage             String?
  featuredIds           String @default("[]")
  announcementBarText   String @default("")
  announcementBarEnabled Boolean @default(false)
  promoBannerText       String @default("")
  promoBannerImage      String?
  promoBannerLink       String?
  promoBannerEnabled    Boolean @default(false)
  updatedAt             DateTime @updatedAt
}

model PaymentMethodSetting {
  id                        String   @id @default(cuid())
  provider                  String   @unique
  displayName               String
  enabled                   Boolean  @default(false)
  mode                      String   @default("SANDBOX")
  supportsFullPayment       Boolean  @default(false)
  supportsPartialPayment    Boolean  @default(false)
  supportsCodDeliveryCharge Boolean  @default(false)
  instructions              String?
  credentialsJson           String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model CourierProviderSetting {
  id                        String   @id @default(cuid())
  provider                  String   @unique
  displayName               String
  enabled                   Boolean  @default(false)
  mode                      String   @default("SANDBOX")
  isDefault                 Boolean  @default(false)
  instructions              String?
  credentialsJson           String?
  pickupName                String?
  pickupPhone               String?
  pickupAddress             String?
  pickupCity                String?
  pickupZone                String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model OrderShipment {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierProvider     String    @default("PATHAO")
  status              String    @default("NOT_CREATED")
  trackingCode        String?
  consignmentId       String?
  courierResponseJson String?
  customerNote        String?
  adminNote           String?
  lastCourierUpdate   DateTime?
  lastCourierStatus   String?
  lastCourierPayload  String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model AbandonedCheckout {
  id           String   @id @default(cuid())
  draftToken   String   @unique
  landingSlug  String?
  name         String?
  email        String?
  phone        String?
  address      String?
  productId    String?
  variantId    String?
  quantity     Int?
  size         String?
  color        String?
  deliveryZone String?
  step         String   @default("started")
  couponCode   String?
  subtotal     Int      @default(0)
  discount     Int      @default(0)
  total        Int      @default(0)
  contacted    Boolean  @default(false)
  notes        String?
  data         String   @default("{}")
  source       String?
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  recoveryTokens RecoveryCheckoutToken[]

  @@index([email])
  @@index([draftToken])
}

model RecoveryCheckoutToken {
  id                  String   @id @default(cuid())
  token               String   @unique
  abandonedCheckoutId String
  abandonedCheckout   AbandonedCheckout @relation(fields: [abandonedCheckoutId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime @default(now())
  createdByAdminId    String?
  createdByAdmin      User?    @relation("CreatedRecoveryTokens", fields: [createdByAdminId], references: [id])
}

model SizeChart {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  rows        SizeChartRow[]
  products    ProductSizeChart[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([slug])
}

model SizeChartRow {
  id           String   @id @default(cuid())
  sizeChartId  String
  sizeChart    SizeChart @relation(fields: [sizeChartId], references: [id], onDelete: Cascade)
  label        String
  position     Int      @default(0)
  measurements Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sizeChartId])
}

model ProductSizeChart {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizeChartId String
  sizeChart   SizeChart @relation(fields: [sizeChartId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([productId, sizeChartId])
  @@index([productId])
  @@index([sizeChartId])
}
