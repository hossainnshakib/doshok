generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  firstName     String?
  lastName      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  phoneVerifiedAt DateTime?
  dateOfBirth   DateTime?
  gender        String?
  password      String?
  role          String    @default("customer")
  isActive      Boolean   @default(true)
  status        String    @default("active")
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  addresses     UserAddress[]
  reviews       ProductReview[]
  emailTokens   EmailVerificationToken[]
  resetTokens   PasswordResetToken[]
  recoveryTokensCreated RecoveryCheckoutToken[] @relation("CreatedRecoveryTokens")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model EmailVerificationToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([email])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Category {
  id             String    @id @default(cuid())
  name           String    @unique
  slug           String    @unique
  image          String?
  parentId       String?
  parent         Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children       Category[] @relation("CategoryHierarchy")
  products       Product[]
  seoTitle       String?
  seoDescription String?
  seoKeywords    String?
  seoImage       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([parentId])
}

model Product {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  description        String?
  shortDescription   String?
  price              Int
  oldPrice           Int?
  images             String[]
  categoryId         String
  category           Category         @relation(fields: [categoryId], references: [id])
  variants           ProductVariant[]
  specifications     ProductSpecification[]
  orderItems         OrderItem[]
  stockMovements     StockMovement[]
  sizeCharts         ProductSizeChart[]
  reviews            ProductReview[]
  featured           Boolean          @default(false)
  status             String           @default("Draft")
  pageType           String           @default("NORMAL")
  defaultCouponCode  String?
  landingHeadline    String?
  landingSubheadline String?
  landingCopy        String?
  landingHeroImage   String?
  paymentRuleOverride     String?
  paymentRuleValueOverride Int?
  material           String?
  careInstructions   String?
  seoTitle           String?
  seoDescription     String?
  seoKeywords        String?
  averageRating      Float?
  reviewCount       Int              @default(0)
  seoImage           String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  relatedProducts    ProductRelation[] @relation("ProductRelations")
  targetRelations    ProductRelation[] @relation("ProductTargets")
  landingPageSetting LandingPageSetting?
}

model LandingPageSetting {
  id                          String   @id @default(cuid())
  productId                   String   @unique
  product                     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  paymentOverrideEnabled      Boolean  @default(false)
  paymentRuleOverride         String?
  paymentRuleValueOverride    Int?
  otpOverrideEnabled          Boolean  @default(false)
  otpOverride                 Boolean?
  couponOverrideEnabled       Boolean  @default(false)
  autoCouponCode              String?
  deliveryOverrideEnabled     Boolean  @default(false)
  deliveryFeeOverride         Int?
  quantityLimit               Int?
  customCta                   String?
  customThankYouMessage       String?
  customQuestionField         String?
  urgencyCounterEnabled       Boolean  @default(false)
  hideNormalNavigation        Boolean  @default(false)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model ProductSpecification {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  label     String
  value     String
  position  Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductVariant {
  id               String  @id @default(cuid())
  productId        String
  product          Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size             String
  color            String
  colorHex         String?
  stock            Int     @default(0)
  reservedStock    Int     @default(0)
  lowStockThreshold Int    @default(5)
  sku              String?
  orderItems       OrderItem[]
  stockMovements   StockMovement[]

  @@unique([productId, size, color])
  @@index([productId])
}

model StockMovement {
  id             String   @id @default(cuid())
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  variantId      String?
  variant        ProductVariant? @relation(fields: [variantId], references: [id], onDelete: Cascade)
  orderId        String?
  order          Order?   @relation(fields: [orderId], references: [id])
  orderItemId    String?
  type           String
  quantity       Int
  beforeStock    Int?
  afterStock     Int?
  beforeReserved Int?
  afterReserved  Int?
  reason         String?
  note           String?
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([productId])
  @@index([variantId])
  @@index([orderId])
  @@index([type])
  @@index([createdAt])
}

model DeliveryZone {
  id    String @id @default(cuid())
  name  String @unique
  fee   Int
}

model Address {
  id          String @id @default(cuid())
  division    String
  district    String
  thana       String
  fullAddress String
  phone       String
  orderId     String @unique
  order       Order  @relation(fields: [orderId], references: [id])
}

model UserAddress {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  label         String   @default("Home")
  recipientName String
  phone         String
  addressLine1  String
  addressLine2  String?
  city          String
  zone          String
  postalCode    String?
  divisionId    String?
  districtId    String?
  upazilaId     String?
  divisionName  String?
  districtName  String?
  upazilaName   String?
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
}

model Order {
  id             String          @id @default(cuid())
  orderNumber    String          @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  userId         String?
  user           User?           @relation(fields: [userId], references: [id])
  items          OrderItem[]
  address        Address?
  shipment       OrderShipment?
  stockMovements StockMovement[]
  subtotal       Int
  deliveryFee    Int
  discount       Int             @default(0)
  total          Int
  paidAmount     Int             @default(0)
  paymentMethod  String
  paymentStatus  String          @default("pending")

  orderStatus    String          @default("pending")
  notes          String?
  couponCode     String?
  paymentExpiresAt   DateTime?
  paymentVerifiedAt  DateTime?
  stockRestoredAt     DateTime?
  idempotencyKey      String?   @unique
  productSubtotal     Int       @default(0)
  productDiscount     Int       @default(0)
  deliveryDiscount    Int       @default(0)
  discountedProductTotal Int   @default(0)
  finalDeliveryFee    Int       @default(0)
  payNow              Int       @default(0)
  dueAmount           Int       @default(0)
  paymentRule         String?
  paymentRuleValue    Int?
  paymentRuleSource   String?
  otpVerified         Boolean   @default(false)
  otpVerifiedAt       DateTime?
  couponType          String?
  reservationExpiresAt DateTime?
  refundedAt     DateTime?
  refundAmount   Int              @default(0)
  refundReason   String?
  refundTrxId    String?
  transactions   PaymentTransaction[]
  reviews       ProductReview[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([userId])
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  name      String
  size      String?
  color     String?
  quantity  Int
  price     Int
}

model PaymentTransaction {
  id               String    @id @default(cuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  provider         String    @default("COD")
  trxId            String    @unique
  amount           Int
  status           String    @default("initiated")
  providerResponse String?
  initiatedAt      DateTime  @default(now())
  verifiedAt       DateTime?
  completedAt      DateTime?

  @@index([orderId])
  @@index([trxId])
  @@index([status])
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Int
  type       String   @default("flat")
  minOrder   Int      @default(0)
  maxUses    Int?
  maxUsesPerCustomer Int?
  usedCount  Int      @default(0)
  expiresAt  DateTime?
  active     Boolean  @default(true)
  scope      String   @default("product")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  usages     CouponUsage[]
}

model CouponUsage {
  id          String   @id @default(cuid())
  couponId    String
  coupon      Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  userId      String?
  email       String
  customerKey String
  orderId     String
  createdAt   DateTime @default(now())

  @@unique([couponId, customerKey])
  @@index([couponId, userId])
  @@index([couponId, email])
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model PhoneOtpVerification {
  id                      String    @id @default(cuid())
  phone                   String
  hashedOtp               String
  provider                String    @default("mock")
  status                  String    @default("pending")
  attempts                Int       @default(0)
  resendCount             Int       @default(0)
  lastSentAt              DateTime?
  verifiedAt              DateTime?
  expiresAt               DateTime
  checkoutToken           String?   @unique
  checkoutTokenExpiresAt  DateTime?
  checkoutTokenUsedAt     DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([phone, status])
  @@index([expiresAt])
  @@index([checkoutToken])
}

model CheckoutSetting {
  id                        String   @id @default("checkout")
  checkoutV2Enabled         Boolean  @default(false)
  otpRequired               Boolean  @default(true)
  otpTtlSeconds             Int      @default(300)
  otpCooldownSeconds        Int      @default(30)
  otpMaxResend              Int      @default(5)
  checkoutTokenTtlSeconds   Int      @default(900)
  defaultPaymentRule        String   @default("cod_only")
  defaultPaymentRuleValue   Int?
  onlineReservationHours    Int      @default(2)
  codReservationHours       Int      @default(24)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model SiteSettings {
  id                String   @id @default("default")
  brandName         String   @default("DOSHOK")
  tagline           String   @default("Style That Speaks")
  supportEmail      String   @default("hello@doshok.com")
  phone             String   @default("")
  whatsapp          String?
  facebookUrl       String?
  instagramUrl      String?
  tiktokUrl         String?
  youtubeUrl        String?
  address           String   @default("We deliver across all districts of Bangladesh. Our operation hub is in Chattogram.")
  footerText        String   @default("Premium Bangladeshi fashion for the modern wardrobe.")
  topbarText        String   @default("Inside Chattogram delivery available")
  footerLinks       String   @default("[]")
  headerQuickLinks  String   @default("[]")
  accentColor       String   @default("#364152")
  buttonRadius      String   @default("xl")
  cardRadius        String   @default("1.5rem")
  storefrontTone    String   @default("light")
  adminAccentTone   String   @default("neutral")
  headerLogo        String?
  footerLogo        String?
  favicon           String?
  appleTouchIcon    String?
  defaultSeoTitle   String?
  defaultSeoDescription String?
  defaultSeoImage   String?
  defaultSeoKeywords String?
  updatedAt         DateTime @updatedAt
}

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  subject   String?
  message   String
  status    String   @default("new")
  source    String   @default("contact")
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([createdAt])
}

model HomepageConfig {
  id                    String @id @default("homepage")
  heroTitle             String @default("Doshok — Style That Speaks")
  heroSubtitle          String @default("Premium Bangladeshi fashion for the modern wardrobe.")
  heroImage             String?
  heroCTAText           String @default("Shop Collection")
  heroCTASecondaryText  String @default("About Us")
  featuredIds           String @default("[]")
  announcementBarText   String @default("")
  announcementBarEnabled Boolean @default(false)
  promoBannerText       String @default("")
  promoBannerImage      String?
  promoBannerLink       String?
  promoBannerEnabled    Boolean @default(false)
  sections              String  @default("[]")
  updatedAt             DateTime @updatedAt
}

model PaymentMethodSetting {
  id                        String   @id @default(cuid())
  provider                  String   @unique
  displayName               String
  enabled                   Boolean  @default(false)
  mode                      String   @default("SANDBOX")
  supportsFullPayment       Boolean  @default(false)
  supportsPartialPayment    Boolean  @default(false)
  supportsCodDeliveryCharge Boolean  @default(false)
  instructions              String?
  credentialsJson           String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model CourierProviderSetting {
  id                        String   @id @default(cuid())
  provider                  String   @unique
  displayName               String
  enabled                   Boolean  @default(false)
  mode                      String   @default("SANDBOX")
  isDefault                 Boolean  @default(false)
  instructions              String?
  credentialsJson           String?
  pickupName                String?
  pickupPhone               String?
  pickupAddress             String?
  pickupCity                String?
  pickupZone                String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model OrderShipment {
  id                  String    @id @default(cuid())
  orderId             String    @unique
  order               Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierProvider     String    @default("PATHAO")
  status              String    @default("NOT_CREATED")
  trackingCode        String?
  consignmentId       String?
  courierResponseJson String?
  customerNote        String?
  adminNote           String?
  lastCourierUpdate   DateTime?
  lastCourierStatus   String?
  lastCourierPayload  String?
  collectionAmount    Int       @default(0)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model AbandonedCheckout {
  id           String   @id @default(cuid())
  draftToken   String   @unique
  landingSlug  String?
  name         String?
  email        String?
  phone        String?
  address      String?
  productId    String?
  variantId    String?
  quantity     Int?
  size         String?
  color        String?
  deliveryZone String?
  step         String   @default("started")
  couponCode   String?
  subtotal     Int      @default(0)
  discount     Int      @default(0)
  total        Int      @default(0)
  contacted    Boolean  @default(false)
  notes        String?
  data         String   @default("{}")
  source       String?
  lastSeenAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  recoveryTokens RecoveryCheckoutToken[]

  @@index([email])
  @@index([draftToken])
}

model RecoveryCheckoutToken {
  id                  String   @id @default(cuid())
  token               String   @unique
  abandonedCheckoutId String
  abandonedCheckout   AbandonedCheckout @relation(fields: [abandonedCheckoutId], references: [id], onDelete: Cascade)
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime @default(now())
  createdByAdminId    String?
  createdByAdmin      User?    @relation("CreatedRecoveryTokens", fields: [createdByAdminId], references: [id])
}

model SizeChart {
  id          String         @id @default(cuid())
  name        String
  slug        String         @unique
  description String?
  rows        SizeChartRow[]
  products    ProductSizeChart[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([slug])
}

model SizeChartRow {
  id           String   @id @default(cuid())
  sizeChartId  String
  sizeChart    SizeChart @relation(fields: [sizeChartId], references: [id], onDelete: Cascade)
  label        String
  position     Int      @default(0)
  measurements Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([sizeChartId])
}

model ProductSizeChart {
  id         String    @id @default(cuid())
  productId  String
  product    Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  sizeChartId String
  sizeChart   SizeChart @relation(fields: [sizeChartId], references: [id], onDelete: Cascade)
  createdAt  DateTime  @default(now())

  @@unique([productId, sizeChartId])
  @@index([productId])
  @@index([sizeChartId])
}

model ProductReview {
  id            String    @id @default(cuid())
  productId     String
  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId       String?
  order         Order?    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  rating        Int
  title         String?
  content       String
  isVerifiedBuyer Boolean @default(true)
  status        String    @default("pending")
  approvedAt    DateTime?
  approvedBy    String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([productId, userId])
  @@index([productId])
  @@index([userId])
  @@index([orderId])
  @@index([status])
}

model MenuItem {
  id        String    @id @default(cuid())
  title     String
  url       String
  target    String    @default("_self")
  location  String
  parentId  String?
  parent    MenuItem?  @relation("MenuItemHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MenuItem[] @relation("MenuItemHierarchy")
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([location])
  @@index([parentId])
  @@index([order])
}

model Page {
  id           String   @id @default(cuid())
  title        String
  slug         String   @unique
  excerpt      String?
  content      String
  seoTitle     String?
  seoDescription String?
  seoImage     String?
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model Story {
  id             String   @id @default(cuid())
  title          String
  slug           String   @unique
  excerpt        String?
  content        String
  image          String?
  seoTitle       String?
  seoDescription String?
  seoImage       String?
  seoKeywords    String?
  status         String   @default("draft")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([slug])
  @@index([status])
}

model CareerPost {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  department      String
  location        String
  employmentType  String
  salaryRange     String?
  deadline        DateTime?
  excerpt         String?
  description     String
  responsibilities String?
  requirements    String?
  benefits        String?
  status          String    @default("Draft")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([slug])
  @@index([status])
  @@index([createdAt])
}

model ProductRelation {
  id               String   @id @default(cuid())
  productId        String
  product          Product  @relation("ProductRelations", fields: [productId], references: [id], onDelete: Cascade)
  relatedProductId String
  relatedProduct   Product  @relation("ProductTargets", fields: [relatedProductId], references: [id], onDelete: Cascade)
  type             String
  position         Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productId, relatedProductId, type])
  @@index([productId])
  @@index([relatedProductId])
  @@index([type])
}

model ShortLink {
  id             String    @id @default(cuid())
  title          String
  slug           String    @unique
  destinationUrl String
  type           String    @default("internal") // internal | external
  status         String    @default("active") // active | inactive
  clickCount     Int       @default(0)
  lastClickedAt  DateTime?
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  nofollow       Boolean   @default(false)
  expiresAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([slug])
  @@index([status])
}
