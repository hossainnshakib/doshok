generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          String    @default("admin")
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  image    String?
  products Product[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id                 String           @id @default(cuid())
  name               String
  slug               String           @unique
  description        String?
  price              Int
  oldPrice           Int?
  images             String[]
  categoryId         String
  category           Category         @relation(fields: [categoryId], references: [id])
  variants           ProductVariant[]
  orderItems         OrderItem[]
  featured           Boolean          @default(false)
  status             String           @default("Draft")
  pageType           String           @default("NORMAL")
  defaultCouponCode  String?
  landingHeadline    String?
  landingSubheadline String?
  landingCopy        String?
  landingHeroImage   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
}

model ProductVariant {
  id       String  @id @default(cuid())
  productId String
  product  Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  size     String
  color    String
  colorHex String?
  stock    Int     @default(0)
  sku      String?
  orderItems OrderItem[]

  @@unique([productId, size, color])
}

model DeliveryZone {
  id    String @id @default(cuid())
  name  String @unique
  fee   Int
}

model Address {
  id          String @id @default(cuid())
  division    String
  district    String
  thana       String
  fullAddress String
  phone       String
  orderId     String @unique
  order       Order  @relation(fields: [orderId], references: [id])
}

model Order {
  id             String          @id @default(cuid())
  orderNumber    String          @unique
  customerName   String
  customerEmail  String
  customerPhone  String
  items          OrderItem[]
  address        Address?
  shipment       OrderShipment?
  subtotal       Int
  deliveryFee    Int
  discount       Int             @default(0)
  total          Int
  paidAmount     Int             @default(0)
  paymentMethod  String
  paymentStatus  String          @default("pending")
  bkashTrxId     String?
  orderStatus    String          @default("pending")
  notes          String?
  couponCode     String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model OrderItem {
  id        String         @id @default(cuid())
  orderId   String
  order     Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product        @relation(fields: [productId], references: [id])
  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])
  name      String
  size      String?
  color     String?
  quantity  Int
  price     Int
}

model Coupon {
  id         String   @id @default(cuid())
  code       String   @unique
  discount   Int
  type       String   @default("flat")
  minOrder   Int      @default(0)
  maxUses    Int?
  usedCount  Int      @default(0)
  expiresAt  DateTime?
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model OtpVerification {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model SiteSettings {
  id            String @id @default("default")
  brandName     String @default("DOSHOK")
  supportEmail  String @default("hello@doshok.com")
  phone         String @default("")
  whatsapp      String?
  facebookUrl   String?
  instagramUrl  String?
  address       String @default("We deliver across all districts of Bangladesh. Our operation hub is in Chattogram.")
  footerText    String @default("Premium Bangladeshi fashion for the modern wardrobe.")
  updatedAt     DateTime @updatedAt
}

model HomepageConfig {
  id               String @id @default("homepage")
  heroTitle        String @default("Doshok — Style That Speaks")
  heroSubtitle     String @default("Premium Bangladeshi fashion for the modern wardrobe.")
  heroImage        String?
  featuredIds      String @default("[]")
  updatedAt        DateTime @updatedAt
}

model PaymentMethodSetting {
  id                        String   @id @default(cuid())
  provider                  String   @unique
  displayName               String
  enabled                   Boolean  @default(false)
  mode                      String   @default("SANDBOX")
  supportsFullPayment       Boolean  @default(false)
  supportsPartialPayment    Boolean  @default(false)
  supportsCodDeliveryCharge Boolean  @default(false)
  instructions              String?
  credentialsJson           String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model CourierProviderSetting {
  id                        String   @id @default(cuid())
  provider                  String   @unique
  displayName               String
  enabled                   Boolean  @default(false)
  mode                      String   @default("SANDBOX")
  isDefault                 Boolean  @default(false)
  instructions              String?
  credentialsJson           String?
  pickupName                String?
  pickupPhone               String?
  pickupAddress             String?
  pickupCity                String?
  pickupZone                String?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model OrderShipment {
  id                  String   @id @default(cuid())
  orderId             String   @unique
  order               Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  courierProvider     String   @default("PATHAO")
  status              String   @default("NOT_CREATED")
  trackingCode        String?
  consignmentId       String?
  courierResponseJson String?
  customerNote        String?
  adminNote           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model AbandonedCheckout {
  id           String   @id @default(cuid())
  landingSlug  String?
  name         String?
  email        String?
  phone        String?
  address      String?
  productId    String?
  variantId    String?
  quantity     Int?
  size         String?
  color        String?
  deliveryZone String?
  step         String   @default("started")
  couponCode   String?
  subtotal     Int      @default(0)
  discount     Int      @default(0)
  total        Int      @default(0)
  contacted    Boolean  @default(false)
  notes        String?
  data         String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
